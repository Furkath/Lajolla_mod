<scene version="2.1.0">

<!-- Defaults, these can be set via the command line: -Darg=value -->

	<default name="spp" value="4096"/>
	<default name="resx" value="1080"/>
	<default name="resy" value="1080"/>

<!-- Camera and Rendering Parameters -->

	<integrator type="path" id="elm__0" name="elm__0">
		<integer name="max_depth" value="12"/>
	</integrator>
	<sensor type="perspective" id="elm__2" name="elm__2">
		<string name="fov_axis" value="x"/>
		<float name="fov" value="39.597755"/>
		<float name="principal_point_offset_x" value="0.000000"/>
		<float name="principal_point_offset_y" value="-0.000000"/>
		<float name="near_clip" value="0.100000"/>
		<float name="far_clip" value="100.000000"/>
		<transform name="to_world">
			<rotate x="1" angle="177.64083034887724"/>
			<rotate y="1" angle="-0.025279655698707854"/>
			<rotate z="1" angle="179.99997768819966"/>
			<translate value="0.000139 1.416879 0.394688"/>
		</transform>
		<sampler type="independent" name="sampler">
			<integer name="sample_count" value="$spp"/>
		</sampler>
		<film type="hdrfilm" name="film">
			<integer name="width" value="$resx"/>
			<integer name="height" value="$resy"/>
		</film>
	</sensor>

<!-- Materials -->

	<bsdf type="npr" id="mat-face" name="mat-face">
		<texture type="bitmap" name="diffuse_color">
			<string name="filename" value="textures/face.png"/>
		</texture>
		<rgb name="metallic_color" value="0.0, 0.0, 0.0"/>
		<float name="Fac" value="0.02"/>
		<float name="diffuse_roughness" value="0.0"/>
		<float name="metallic_roughness" value="1.0"/>

		<!-- if no specify, use diffuse_color texture alpha channel; 
		if no texture or texture no alpha, default to 1.0 --> 
		<!-- <float name="Fac2" value="0.5"/>  --> 
	</bsdf>

<!-- Emitters -->
