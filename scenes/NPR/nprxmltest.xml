		<rgb value="79.577469 79.577469 79.577469" name="intensity"/>
		<float name="scale" value="0.1"/>
	</emitter>
	<emitter type="point" id="elm__5" name="elm__5">
		<point name="position" x="-4.076250076293945" y="2.903860092163086" z="2.0054500102996826"/>
		<rgb value="79.577469 79.577469 79.577469" name="intensity"/>
		<float name="scale" value="0.1"/>
	</emitter>
	-->
	<emitter type="point" id="elm__6" name="elm__6">
		<point name="position" x="0.0" y="5.903860092163086" z="2.0054500102996826"/>
		<rgb value="79.577469 79.577469 79.577469" name="intensity"/>
		<float name="scale" value="0.1"/>
	</emitter>
	<emitter type="constant">
    		<rgb name="radiance" value="0.06 0.06 0.06"/>
	</emitter>

<!-- Shapes -->

	<shape type="ply" id="elm__4" name="elm__4">
		<string name="filename" value="meshes/mod_face.ply"/>
		<ref id="mat-face" name="bsdf"/>
	</shape>

<!-- Volumes -->

</scene>
